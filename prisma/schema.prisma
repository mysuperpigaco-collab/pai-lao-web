// ============================================================
//  Prisma Schema - ไปเล่า (Pai-Lao)
//  Version 2.0
// ============================================================

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [pg_trgm]
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

// ── Enums ────────────────────────────────────────────────────

enum Role {
  TRAVELER
  BUSINESS
  ADMIN
  SUPERADMIN
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

// PlaceCategory values: NATURE | CAFE | ACCOMMODATION | CAMPING | FOOD | TEMPLE | BEACH | MARKET | ADVENTURE | MUSEUM

// ── User ─────────────────────────────────────────────────────

model User {
  id          String    @id @default(uuid())
  firstName   String
  lastName    String
  username    String    @unique
  email       String    @unique
  phone       String?
  password    String?

  googleId     String?  @unique           // Google OAuth subject id (ลิงก์บัญชี Google)
  authProvider String   @default("LOCAL") // LOCAL | GOOGLE

  displayName String?
  birthDate   DateTime?
  gender      Gender?
  avatarUrl      String?
  coverUrl       String?
  profileCovers  String[]   // รูปสไลด์โชว์ปกโปรไฟล์ สูงสุด 5 รูป
  bio            String?

  lineId      String?
  facebook    String?
  instagram   String?
  tiktok      String?

  role        Role      @default(TRAVELER)

  tripGalleryLimit  Int  @default(50)  // จำนวนรูป gallery สูงสุดต่อทริป (admin ปรับได้: 50/100/150/200)

  postBannedUntil DateTime?  // ห้ามโพสจนถึงวันที่นี้ (null = ไม่ถูกแบน)
  bannedUntil     DateTime?  // บัญชีถูกระงับจนถึงวันที่นี้ (null = ไม่ถูกแบน)
  banReason       String?    // เหตุผลที่ถูกแบน
  resetToken      String?    // token สำหรับรีเซ็ตรหัสผ่าน
  resetTokenExp   DateTime?  // วันหมดอายุ token
  emailVerified      Boolean   @default(false) // ยืนยันอีเมลแล้วหรือยัง
  emailVerifyToken   String?   // token สำหรับยืนยันอีเมล
  emailVerifyExp     DateTime? // วันหมดอายุ token ยืนยันอีเมล
  missionsCreated       Mission[]            @relation("MissionCreator")
  announcements         Announcement[]       @relation("AnnouncementCreator")
  missionParticipations MissionParticipant[]
  points                Int      @default(0)

  // Privacy settings
  profilePrivacy  String    @default("PUBLIC")  // PUBLIC | PRIVATE
  showEmail       Boolean   @default(false)
  showPhone       Boolean   @default(false)
  showSocial      Boolean   @default(true)
  showBirthDate   Boolean   @default(false)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  trips         Trip[]
  reviews       Review[]
  reviewReplies ReviewReply[]
  bookmarks     Bookmark[]
  business      Business?
  tripLikes     TripLike[]
  placeLikes    PlaceLike[]
  following     Follow[]      @relation("Follower")
  followers     Follow[]      @relation("Following")
  reports       Report[]
  pendingEdits  PendingEdit[]
  tripPlans     TripPlan[]
}

// ── Business ─────────────────────────────────────────────────

model Business {
  id           String   @id @default(uuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  businessName String
  contactName  String?
  description  String?
  province     String?
  district     String?
  country      String   @default("Thailand")
  website      String?
  logoUrl      String?
  coverUrl     String?

  phone        String?
  email        String?
  lineId       String?
  facebook     String?
  instagram    String?
  tiktok       String?
  categories   String[]

  isVerified   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  places       Place[]
  claims       PlaceClaim[]  @relation("BusinessClaims")
  promotions   Promotion[]   @relation("BusinessPromotions")
}

// ── Place ─────────────────────────────────────────────────────

model Place {
  id               String        @id @default(uuid())
  slug             String        @unique
  title            String
  titleEn          String?

  province         String
  district         String
  address          String?
  googleMapsUrl    String?
  lat              Float?
  lng              Float?

  category         String
  tags             String[]

  coverUrl         String
  gallery          String[]

  description      String
  descriptionShort String?
  openHours        String?
  closedDays       String?
  entryFee         String?
  phone            String?
  website          String?
  lineId           String?

  amenities        String[]  // e.g. PARKING, WIFI, RESTROOM, AIRCON, ACCESSIBLE, CREDIT_CARD, RESTAURANT, CAFE, CHARGING, ELEVATOR, POOL, PHOTO_SPOT
  petPolicy        String?   // ALLOWED | NOT_ALLOWED | CONDITIONS

  shareCount       Int       @default(0)
  viewCount        Int       @default(0)

  approvalStatus   String    @default("PENDING") // PENDING | APPROVED | REJECTED
  rejectionReason  String?
  isVerified       Boolean   @default(false)
  businessId       String?
  business         Business? @relation(fields: [businessId], references: [id], onDelete: SetNull)

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  reviews          Review[]
  bookmarks        Bookmark[]
  timelineStops    TimelineStop[]
  likes            PlaceLike[]
  claims           PlaceClaim[]
  planStops        TripPlanStop[]
  missions         Mission[]     @relation("MissionPlace")
  promotions       Promotion[]   @relation("PromotionPlace")

  // GIN trgm — เร่ง `contains` (ILIKE %q%) ของช่องค้นหา (ดู /api/places OR clause)
  @@index([title(ops: raw("gin_trgm_ops"))], type: Gin)
  @@index([description(ops: raw("gin_trgm_ops"))], type: Gin)
  @@index([province(ops: raw("gin_trgm_ops"))], type: Gin)
}

// ── Trip ──────────────────────────────────────────────────────

model Trip {
  id          String   @id @default(uuid())
  slug        String   @unique
  title       String
  subtitle    String?
  description String
  coverUrl    String
  gallery     String[]

  mood        String        // ตัวหลัก (= moods[0]) เก็บไว้เพื่อ backward-compat
  moods       String[]      @default([])  // หลายสไตล์ของทริป (multi-select)
  titleStyle  String?       @default("none") // สไตล์สี/ฟอนต์ของหัวข้อ (none|bold|serif|red|sunset|ocean|purple|gold)
  budget      Int?
  location    String?
  tags        String[]

  youtubeUrl    String?
  tiktokUrl     String?
  shareCount    Int      @default(0)
  viewCount     Int      @default(0)

  durationDays  Int?     // จำนวนวัน
  tripStyle     String?  // SOLO | COUPLE | FAMILY | FRIENDS
  transportMode String?  // รถยนต์ | รถทัวร์ | เครื่องบิน | รถไฟ | เรือ | มอเตอร์ไซค์ | ผสม

  isDraft          Boolean  @default(false)  // บันทึกชั่วคราวขณะท่องเที่ยว
  isPublished      Boolean  @default(false)
  approvalStatus   String?  // PENDING | APPROVED | REJECTED (null when isDraft)
  rejectionReason  String?
  authorId         String
  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  timeline    TimelineStop[]
  reviews     Review[]
  bookmarks   Bookmark[]
  likes       TripLike[]

  // GIN trgm — เร่ง `contains` ของช่องค้นหา (ดู /api/trips OR clause)
  @@index([title(ops: raw("gin_trgm_ops"))], type: Gin)
  @@index([subtitle(ops: raw("gin_trgm_ops"))], type: Gin)
}

// ── TimelineStop ──────────────────────────────────────────────

model TimelineStop {
  id          String  @id @default(uuid())
  tripId      String
  trip        Trip    @relation(fields: [tripId], references: [id], onDelete: Cascade)
  order       Int

  date        String
  time        String?

  placeName   String
  province    String
  district    String

  description String
  transport   String?
  duration    String?
  cost        String?
  images      String[]

  stopType      String?  // ATTRACTION | EAT | SLEEP | ACTIVITY | TRANSPORT
  googleMapsUrl String?  // Google Maps URL
  tips          String?  // เคล็ดลับ/ข้อควรรู้

  placeId      String?
  place        Place?  @relation(fields: [placeId], references: [id], onDelete: SetNull)
  shareToPlace Boolean @default(false) // แชร์รูปไปยังหน้าสถานที่
  rating       Int?                    // คะแนนรีวิวของจุดนี้ (1-5) ใช้ตอน autoPlaceReviews

  lat          Float?
  lng          Float?

  @@index([tripId])
  @@index([order])
  @@index([placeId])
  @@index([placeName])
  // GIN trgm — ค้นทริปตามจังหวัด (timeline.some.province contains)
  @@index([province(ops: raw("gin_trgm_ops"))], type: Gin)
}

// ── Review ────────────────────────────────────────────────────

model Review {
  id        String   @id @default(uuid())
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  tripId    String?
  trip      Trip?    @relation(fields: [tripId], references: [id], onDelete: Cascade)
  placeId   String?
  place     Place?   @relation(fields: [placeId], references: [id], onDelete: Cascade)

  rating      Int
  text        String
  isAnonymous Boolean  @default(false)
  isHidden    Boolean  @default(false)  // เจ้าของรีวิวซ่อนจากโปรไฟล์
  likes       Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  replies   ReviewReply[]

  @@index([tripId])
  @@index([placeId])
  @@index([authorId])
}

// ── ReviewReply ───────────────────────────────────────────────

model ReviewReply {
  id        String   @id @default(uuid())
  reviewId  String
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  text      String
  createdAt DateTime @default(now())

  @@index([reviewId])
}

// ── Bookmark ──────────────────────────────────────────────────

model Bookmark {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  tripId    String?
  trip      Trip?    @relation(fields: [tripId], references: [id], onDelete: Cascade)
  placeId   String?
  place     Place?   @relation(fields: [placeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, tripId])
  @@unique([userId, placeId])
  @@index([userId])
}

// ── TripLike ──────────────────────────────────────────────────

model TripLike {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tripId    String
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, tripId])
  @@index([tripId])
  @@index([userId])
}

// ── PlaceLike ─────────────────────────────────────────────────

model PlaceLike {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  placeId   String
  place     Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, placeId])
  @@index([placeId])
  @@index([userId])
}

// ── Follow ────────────────────────────────────────────────────

model Follow {
  id          String   @id @default(uuid())
  followerId  String
  follower    User     @relation("Follower",  fields: [followerId],  references: [id], onDelete: Cascade)
  followingId String
  following   User     @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

// ── Report ───────────────────────────────────────────────
model Report {
  id         String   @id @default(uuid())
  reporterId String
  reporter   User     @relation(fields: [reporterId], references: [id], onDelete: Cascade)
  targetId   String
  targetType String   // "REVIEW" | "REPLY" | "TRIP" | "PLACE" | "USER"
  reason     String   // "SPAM" | "INAPPROPRIATE" | "FAKE" | "HARASSMENT" | "OTHER"
  detail     String?
  status     String   @default("PENDING") // "PENDING" | "REVIEWED" | "DISMISSED"
  createdAt  DateTime @default(now())

  @@index([reporterId])
  @@index([targetId])
}

// ── AdminLog ─────────────────────────────────────────────────
model PendingEdit {
  id              String   @id @default(uuid())
  targetType      String   // "TRIP" | "PLACE"
  targetId        String
  originalData    Json     // snapshot ของข้อมูลเดิม
  pendingData     Json     // ข้อมูลใหม่ที่รอตรวจสอบ
  status          String   @default("PENDING") // PENDING | APPROVED | REJECTED
  rejectionReason String?
  submittedById   String
  submittedBy     User     @relation(fields: [submittedById], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status])
  @@index([targetId])
}

model AdminLog {
  id         String   @id @default(uuid())
  adminId    String
  action     String   // "BAN_USER" | "CHANGE_ROLE" | "DELETE_TRIP" | "DELETE_PLACE" | "RESOLVE_REPORT" | "DISMISS_REPORT" | "VERIFY_PLACE" | "UNVERIFY_PLACE" | "UNPUBLISH_TRIP"
  targetId   String?
  targetType String?  // "USER" | "TRIP" | "PLACE" | "REPORT"
  detail     String?
  createdAt  DateTime @default(now())

  @@index([adminId])
  @@index([createdAt])
}

// ── UserActivityLog (พ.ร.บ. คอมพิวเตอร์ มาตรา 26 — เก็บ 90 วัน) ──
// บันทึกกิจกรรมสำคัญของผู้ใช้: สมัคร, reset password, สร้าง/ลบ content, อัปโหลด, รีวิว, รายงาน

model UserActivityLog {
  id         String   @id @default(uuid())
  userId     String?  // null = ยังไม่ได้ login
  username   String?
  action     String   // ดูค่าได้ใน lib/activityLogger.ts
  ip         String
  userAgent  String?
  targetId   String?  // id ของ trip/place/review ที่เกี่ยวข้อง
  targetType String?  // "TRIP" | "PLACE" | "REVIEW" | "REPORT" | "FILE"
  detail     String?  // ข้อมูลเพิ่มเติม เช่น ชื่อ trip
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@index([ip])
  @@index([action])
}

// ── LoginLog (พ.ร.บ. คอมพิวเตอร์ มาตรา 26 — เก็บ 90 วัน) ──

model LoginLog {
  id        String   @id @default(uuid())
  userId    String?  // null = login ล้มเหลว (ไม่รู้ว่าใคร)
  username  String?  // เก็บไว้แม้ user ถูกลบ
  action    String   // "LOGIN_SUCCESS" | "LOGIN_FAILED" | "LOGOUT"
  ip        String   // IP address ของผู้ใช้
  userAgent String?  // Browser / device info
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@index([ip])
}

// ── TripPlan ──────────────────────────────────────────────

model TripPlan {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String?
  coverUrl    String?
  startDate   String?
  endDate     String?
  province    String?
  isPublic    Boolean  @default(false)
  stops       TripPlanStop[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

model TripPlanStop {
  id            String   @id @default(uuid())
  planId        String
  plan          TripPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  order         Int
  name          String
  province      String?
  district      String?
  notes         String?
  googleMapsUrl String?
  stopType      String?  // ATTRACTION | EAT | SLEEP | ACTIVITY | TRANSPORT
  day           Int      @default(1)  // วันที่ในทริป
  arrivalTime   String?  // เวลาที่คาดว่าจะถึง เช่น "09:00"
  duration      Int?     // ระยะเวลาที่ใช้ที่จุดนี้ (นาที)
  placeId       String?
  place         Place?   @relation(fields: [placeId], references: [id], onDelete: SetNull)

  @@index([planId])
}


// ── PlaceClaim ─────────────────────────────────────────────
model PlaceClaim {
  id          String   @id @default(uuid())
  placeId     String
  place       Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)
  businessId  String
  business    Business @relation("BusinessClaims", fields: [businessId], references: [id], onDelete: Cascade)
  status      String   @default("PENDING") // PENDING | APPROVED | REJECTED
  message     String?  // ข้อความยืนยันจากเจ้าของ
  adminNote   String?  // หมายเหตุจากแอดมิน
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([placeId, businessId])
  @@index([status])
}

// ── V2: Mission System ────────────────────────────────────

model Mission {
  id           String   @id @default(uuid())
  title        String
  description  String
  coverUrl     String?
  placeId      String?
  place        Place?   @relation("MissionPlace", fields: [placeId], references: [id], onDelete: SetNull)
  province     String?
  district     String?
  reward       String?  // รางวัล เช่น "50 แต้ม" หรือ "Badge นักสำรวจ"
  rewardPoints Int      @default(0)
  badgeLabel   String?  // ชื่อ badge ที่จะได้รับ
  startDate    DateTime
  endDate      DateTime
  maxSlots     Int?     // จำนวนคนสูงสุดที่รับภารกิจได้
  status       String   @default("ACTIVE") // ACTIVE | INACTIVE | EXPIRED
  createdById  String
  createdBy    User     @relation("MissionCreator", fields: [createdById], references: [id])
  participants MissionParticipant[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([status])
  @@index([endDate])
}

model MissionParticipant {
  id          String   @id @default(uuid())
  missionId   String
  mission     Mission  @relation(fields: [missionId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  status      String   @default("JOINED") // JOINED | SUBMITTED | APPROVED | REJECTED
  photoUrls   String[] // รูปที่ส่งมา
  reviewText  String?  // ข้อความรีวิว
  placeId     String?
  adminNote   String?
  visitedAt   DateTime? // วันเวลาที่ผู้ส่งไปสถานที่จริง
  submittedAt DateTime?
  approvedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([missionId, userId])
  @@index([userId])
  @@index([status])
}

// ── V2: Promotion System ──────────────────────────────────

model Promotion {
  id          String   @id @default(uuid())
  businessId  String
  business    Business @relation("BusinessPromotions", fields: [businessId], references: [id], onDelete: Cascade)
  placeId     String?
  place       Place?   @relation("PromotionPlace", fields: [placeId], references: [id], onDelete: SetNull)
  title       String
  description String
  coverUrl    String?
  discount    String?  // เช่น "ลด 20%" หรือ "ซื้อ 1 แถม 1"
  condition   String?  // เงื่อนไข
  startDate   DateTime
  endDate     DateTime
  status      String   @default("PENDING") // PENDING | ACTIVE | REJECTED | EXPIRED
  adminNote   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([businessId])
  @@index([status])
  @@index([endDate])
}

model SiteSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// ── Announcement (admin → user notifications) ─────────────
model Announcement {
  id          String    @id @default(uuid())
  title       String
  body        String
  icon        String    @default("📢")
  type        String    @default("info") // info | warning | success | tip
  targetRole  String?   // null = all users | TRAVELER | BUSINESS
  isActive    Boolean   @default(true)
  expiresAt   DateTime?
  createdById String
  createdBy   User      @relation("AnnouncementCreator", fields: [createdById], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([isActive])
  @@index([createdAt])
}
