// ============================================================
//  Prisma Schema - ไปเล่า (Pai-Lao)
//  Version 2.0
// ============================================================

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ── Enums ────────────────────────────────────────────────────

enum Role {
  TRAVELER
  BUSINESS
  ADMIN
  SUPERADMIN
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum PlaceCategory {
  NATURE
  CAFE
  ACCOMMODATION
  CAMPING
  FOOD
  TEMPLE
  BEACH
  MARKET
  ADVENTURE
  MUSEUM
}

// ── User ─────────────────────────────────────────────────────

model User {
  id          String    @id @default(uuid())
  firstName   String
  lastName    String
  username    String    @unique
  email       String    @unique
  phone       String
  password    String

  displayName String?
  birthDate   DateTime?
  gender      Gender?
  avatarUrl      String?
  coverUrl       String?
  profileCovers  String[]   // รูปสไลด์โชว์ปกโปรไฟล์ สูงสุด 5 รูป
  bio            String?

  lineId      String?
  facebook    String?
  instagram   String?
  tiktok      String?

  role        Role      @default(TRAVELER)

  postBannedUntil DateTime?  // ห้ามโพสจนถึงวันที่นี้ (null = ไม่ถูกแบน)
  bannedUntil     DateTime?  // บัญชีถูกระงับจนถึงวันที่นี้ (null = ไม่ถูกแบน)
  banReason       String?    // เหตุผลที่ถูกแบน
  resetToken      String?    // token สำหรับรีเซ็ตรหัสผ่าน
  resetTokenExp   DateTime?  // วันหมดอายุ token

  // Privacy settings
  profilePrivacy  String    @default("PUBLIC")  // PUBLIC | PRIVATE
  showEmail       Boolean   @default(false)
  showPhone       Boolean   @default(false)
  showSocial      Boolean   @default(true)
  showBirthDate   Boolean   @default(false)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  trips         Trip[]
  reviews       Review[]
  reviewReplies ReviewReply[]
  bookmarks     Bookmark[]
  business      Business?
  tripLikes     TripLike[]
  placeLikes    PlaceLike[]
  following     Follow[]      @relation("Follower")
  followers     Follow[]      @relation("Following")
  reports       Report[]
  pendingEdits  PendingEdit[]
  tripPlans     TripPlan[]
}

// ── Business ─────────────────────────────────────────────────

model Business {
  id           String   @id @default(uuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  businessName String
  contactName  String?
  description  String?
  province     String?
  district     String?
  country      String   @default("Thailand")
  website      String?
  logoUrl      String?
  coverUrl     String?

  phone        String?
  email        String?
  lineId       String?
  facebook     String?
  instagram    String?
  tiktok       String?
  categories   String[]

  isVerified   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  places       Place[]
  claims       PlaceClaim[]
}

// ── Place ─────────────────────────────────────────────────────

model Place {
  id               String        @id @default(uuid())
  slug             String        @unique
  title            String
  titleEn          String?

  province         String
  district         String
  address          String?
  googleMapsUrl    String?
  lat              Float?
  lng              Float?

  category         PlaceCategory
  tags             String[]

  coverUrl         String
  gallery          String[]

  description      String
  descriptionShort String?
  openHours        String?
  closedDays       String?
  entryFee         String?
  phone            String?
  website          String?
  lineId           String?

  amenities        String[]  // e.g. PARKING, WIFI, RESTROOM, AIRCON, ACCESSIBLE, CREDIT_CARD, RESTAURANT, CAFE, CHARGING, ELEVATOR, POOL, PHOTO_SPOT
  petPolicy        String?   // ALLOWED | NOT_ALLOWED | CONDITIONS

  shareCount       Int       @default(0)
  viewCount        Int       @default(0)

  approvalStatus   String    @default("PENDING") // PENDING | APPROVED | REJECTED
  rejectionReason  String?
  isVerified       Boolean   @default(false)
  businessId       String?
  business         Business? @relation(fields: [businessId], references: [id], onDelete: SetNull)

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  reviews          Review[]
  bookmarks        Bookmark[]
  timelineStops    TimelineStop[]
  likes            PlaceLike[]
  claims           PlaceClaim[]
  planStops        TripPlanStop[]
}

// ── Trip ──────────────────────────────────────────────────────

model Trip {
  id          String   @id @default(uuid())
  slug        String   @unique
  title       String
  subtitle    String?
  description String
  coverUrl    String
  gallery     String[]

  mood        String
  budget      Int?
  location    String?
  tags        String[]

  youtubeUrl    String?
  tiktokUrl     String?
  shareCount    Int      @default(0)
  viewCount     Int      @default(0)

  durationDays  Int?     // จำนวนวัน
  tripStyle     String?  // SOLO | COUPLE | FAMILY | FRIENDS
  transportMode String?  // รถยนต์ | รถทัวร์ | เครื่องบิน | รถไฟ | เรือ | มอเตอร์ไซค์ | ผสม

  isDraft          Boolean  @default(false)  // บันทึกชั่วคราวขณะท่องเที่ยว
  isPublished      Boolean  @default(false)
  approvalStatus   String?  // PENDING | APPROVED | REJECTED (null when isDraft)
  rejectionReason  String?
  authorId         String
  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  timeline    TimelineStop[]
  reviews     Review[]
  bookmarks   Bookmark[]
  likes       TripLike[]
}

// ── TimelineStop ──────────────────────────────────────────────

model TimelineStop {
  id          String  @id @default(uuid())
  tripId      String
  trip        Trip    @relation(fields: [tripId], references: [id], onDelete: Cascade)
  order       Int

  date        String
  time        String?

  placeName   String
  province    String
  district    String

  description String
  transport   String?
  duration    String?
  cost        String?
  images      String[]

  stopType      String?  // ATTRACTION | EAT | SLEEP | ACTIVITY | TRANSPORT
  googleMapsUrl String?  // Google Maps URL
  tips          String?  // เคล็ดลับ/ข้อควรรู้

  placeId     String?
  place       Place?  @relation(fields: [placeId], references: [id], onDelete: SetNull)

  @@index([tripId])
  @@index([order])
}

// ── Review ────────────────────────────────────────────────────

model Review {
  id        String   @id @default(uuid())
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  tripId    String?
  trip      Trip?    @relation(fields: [tripId], references: [id], onDelete: Cascade)
  placeId   String?
  place     Place?   @relation(fields: [placeId], references: [id], onDelete: Cascade)

  rating      Int
  text        String
  isAnonymous Boolean  @default(false)
  isHidden    Boolean  @default(false)  // เจ้าของรีวิวซ่อนจากโปรไฟล์
  likes       Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  replies   ReviewReply[]

  @@index([tripId])
  @@index([placeId])
  @@index([authorId])
}

// ── ReviewReply ───────────────────────────────────────────────

model ReviewReply {
  id        String   @id @default(uuid())
  reviewId  String
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  text      String
  createdAt DateTime @default(now())

  @@index([reviewId])
}

// ── Bookmark ──────────────────────────────────────────────────

model Bookmark {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  tripId    String?
  trip      Trip?    @relation(fields: [tripId], references: [id], onDelete: Cascade)
  placeId   String?
  place     Place?   @relation(fields: [placeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, tripId])
  @@unique([userId, placeId])
  @@index([userId])
}

// ── TripLike ──────────────────────────────────────────────────

model TripLike {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tripId    String
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, tripId])
  @@index([tripId])
  @@index([userId])
}

// ── PlaceLike ─────────────────────────────────────────────────

model PlaceLike {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  placeId   String
  place     Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, placeId])
  @@index([placeId])
  @@index([userId])
}

// ── Follow ────────────────────────────────────────────────────

model Follow {
  id          String   @id @default(uuid())
  followerId  String
  follower    User     @relation("Follower",  fields: [followerId],  references: [id], onDelete: Cascade)
  followingId String
  following   User     @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

// ── Report ───────────────────────────────────────────────
model Report {
  id         String   @id @default(uuid())
  reporterId String
  reporter   User     @relation(fields: [reporterId], references: [id], onDelete: Cascade)
  targetId   String
  targetType String   // "REVIEW" | "REPLY" | "TRIP" | "PLACE" | "USER"
  reason     String   // "SPAM" | "INAPPROPRIATE" | "FAKE" | "HARASSMENT" | "OTHER"
  detail     String?
  status     String   @default("PENDING") // "PENDING" | "REVIEWED" | "DISMISSED"
  createdAt  DateTime @default(now())

  @@index([reporterId])
  @@index([targetId])
}

// ── AdminLog ─────────────────────────────────────────────────
model PendingEdit {
  id              String   @id @default(uuid())
  targetType      String   // "TRIP" | "PLACE"
  targetId        String
  originalData    Json     // snapshot ของข้อมูลเดิม
  pendingData     Json     // ข้อมูลใหม่ที่รอตรวจสอบ
  status          String   @default("PENDING") // PENDING | APPROVED | REJECTED
  rejectionReason String?
  submittedById   String
  submittedBy     User     @relation(fields: [submittedById], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status])
  @@index([targetId])
}

model AdminLog {
  id         String   @id @default(uuid())
  adminId    String
  action     String   // "BAN_USER" | "CHANGE_ROLE" | "DELETE_TRIP" | "DELETE_PLACE" | "RESOLVE_REPORT" | "DISMISS_REPORT" | "VERIFY_PLACE" | "UNVERIFY_PLACE" | "UNPUBLISH_TRIP"
  targetId   String?
  targetType String?  // "USER" | "TRIP" | "PLACE" | "REPORT"
  detail     String?
  createdAt  DateTime @default(now())

  @@index([adminId])
  @@index([createdAt])
}

// ── TripPlan ──────────────────────────────────────────────

model TripPlan {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String?
  coverUrl    String?
  startDate   String?
  endDate     String?
  province    String?
  isPublic    Boolean  @default(false)
  stops       TripPlanStop[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

model TripPlanStop {
  id            String   @id @default(uuid())
  planId        String
  plan          TripPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  order         Int
  name          String
  province      String?
  district      String?
  notes         String?
  googleMapsUrl String?
  stopType      String?  // ATTRACTION | EAT | SLEEP | ACTIVITY | TRANSPORT
  day           Int      @default(1)  // วันที่ในทริป
  arrivalTime   String?  // เวลาที่คาดว่าจะถึง เช่น "09:00"
  duration      Int?     // ระยะเวลาที่ใช้ที่จุดนี้ (นาที)
  placeId       String?
  place         Place?   @relation(fields: [placeId], references: [id], onDelete: SetNull)

  @@index([planId])
}


// ── PlaceClaim ─────────────────────────────────────────────
model PlaceClaim {
  id          String   @id @default(uuid())
  placeId     String
  place       Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  status      String   @default("PENDING") // PENDING | APPROVED | REJECTED
  message     String?  // ข้อความยืนยันจากเจ้าของ
  adminNote   String?  // หมายเหตุจากแอดมิน
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([placeId, businessId])
  @@index([status])
}
